// Prisma schema for Comity. The data model below covers users, sessions,
// analyses, the preset project corpus, the methodology phases, the
// bibliography, and recommendation records. Edit with care; migrations
// must follow a structured change-management process when the live
// database has user data.

generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  role          String    @default("user")
  approved      Boolean   @default(false)
  githubToken   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  analyses      Analysis[]
  bookmarks     Bookmark[]
  sessions      Session[]
  accounts      Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Analysis {
  id              String   @id @default(cuid())
  userId          String
  repoOwner       String
  repoName        String
  repoFullName    String
  status          String   @default("pending")
  hhiScore        Float?
  hhiRisk         String?
  cri             Json?
  cga             Json?
  mergeAuthority  Json?
  contributors    Json?
  governanceDocs  Json?
  prAnalysis      Json?
  branchRules     Json?
  rawData         Json?
  summary         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([repoFullName])
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  repoOwner  String
  repoName   String
  category   String?
  notes      String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, repoOwner, repoName])
  @@index([userId])
}

model PresetProject {
  id              String   @id @default(cuid())
  owner           String
  repo            String
  name            String
  description     String?
  category        String
  categoryName    String?
  subCategory     String?
  expectedHhi     String?
  license         String?
  licenseType     String?
  claRequired     Boolean  @default(false)
  corporateBackers Json?
  researchRelevance Json?
  primaryLanguage String?
  governanceModel String?
  priority        Int      @default(3)
  isUserAdded     Boolean  @default(false)
  addedByUserId   String?
  tags            Json?
  sbomFormat      String?  // CycloneDX | SPDX | Both | None
  sbomSource      String?  // URL or path to SBOM
  cohort          String?  // Phase 1 repo cohort tag (e.g. 'sbom_cycloneDX', 'sbom_spdx', 'phase1_11')
  createdAt       DateTime @default(now())

  @@unique([owner, repo])
}

model MethodologyPhase {
  id              String   @id @default(cuid())
  phaseNumber     Int
  name            String
  description     String
  inputs          Json?
  outputs         Json?
  method          String?
  sampleSize      String?
  timeWindow      String?
  gating          String?
  createdAt       DateTime @default(now())
}

model DmpSection {
  id              String   @id @default(cuid())
  sectionKey      String   @unique
  title           String
  content         String   @db.Text
  ordinal         Int
  createdAt       DateTime @default(now())
}

model BibliographyEntry {
  id              String   @id @default(cuid())
  citationKey     String   @unique
  authors         String
  year            Int
  title           String
  source          String
  doi             String?
  url             String?
  category        String
  annotation      String?
  relevantTo      Json?
  isPaperSource   Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model Recommendation {
  id              String   @id @default(cuid())
  analysisId      String?
  repoFullName    String?
  type            String
  title           String
  description     String
  rationale       String?
  evidenceData    Json?
  literatureRefs  Json?
  constructsLinked Json?
  severity        String?
  createdAt       DateTime @default(now())

  @@index([type])
  @@index([repoFullName])
}

model SurveyDraft {
  id              String   @id @default(cuid())
  version         String   @default("1.0")
  title           String
  sections        Json
  ethicsNotes     String?
  consentText     String?
  methodology     Json?
  status          String   @default("draft")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
